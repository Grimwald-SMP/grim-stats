{
  "schemaVersion": 1,
  "id": "grimstats",
  "version": "${version}",
  "name": "GrimStats",
  "description": "Lightweight world & player statistics dashboard and API for Fabric servers. Covers all in-game stats, scoreboards, and modded/datapack stats, served from a self-contained embedded web dashboard.",
  "authors": [
    "GrimStats contributors"
  ],
  "contact": {
    "homepage": "https://github.com/Grimwald-SMP/grim-stats",
    "sources": "https://github.com/Grimwald-SMP/grim-stats",
    "issues": "https://github.com/Grimwald-SMP/grim-stats/issues"
  },
  "license": "MIT",
  "icon": "assets/grimstats/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.grimstats.GrimStats"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader}",
    "minecraft": "~1.21.11",
    "java": ">=${java}",
    "fabric-api": "*"
  },
  "suggests": {}
}
